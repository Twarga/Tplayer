{
  "name": "tplayer",
  "productName": "Tplayer",
  "appId": "com.twarga.tplayer",
  "version": "0.3.0",
  "description": "A polished local-first desktop music player with YouTube import.",
  "homepage": "https://twarga.github.io/Tplayer/",
  "main": "./out/main/index.js",
  "author": {
    "name": "twarga"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Twarga/Tplayer.git"
  },
  "license": "MIT",
  "private": true,
  "build": {
    "appId": "com.twarga.tplayer",
    "productName": "Tplayer",
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": [
      "out"
    ],
    "linux": {
      "target": "AppImage",
      "category": "Audio",
      "maintainer": "twarga"
    },
    "win": {
      "target": "nsis",
      "icon": "build/icon.ico"
    }
  },
  "scripts": {
    "postinstall": "electron-builder install-app-deps",
    "dev": "env -u ELECTRON_RUN_AS_NODE electron-vite dev",
    "build": "electron-vite build",
    "package:linux": "npm run build && electron-builder --linux --publish never",
    "package:win": "npm run build && electron-builder --win --publish never",
    "package:dir": "npm run build && electron-builder --dir --publish never",
    "preview": "env -u ELECTRON_RUN_AS_NODE electron-vite preview",
    "lint": "eslint . --ext .ts,.tsx",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-slider": "^1.3.6",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tanstack/react-virtual": "^3.13.24",
    "better-sqlite3": "^12.9.0",
    "chokidar": "^3.6.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dbus-next": "^0.10.2",
    "fluent-ffmpeg": "^2.1.3",
    "framer-motion": "^12.38.0",
    "lucide-react": "^1.14.0",
    "music-metadata": "^7.14.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "tailwind-merge": "^3.5.0",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.4",
    "@types/better-sqlite3": "^7.6.13",
    "@types/fluent-ffmpeg": "^2.1.28",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.59.2",
    "@typescript-eslint/parser": "^8.59.2",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.21",
    "electron": "^33.2.1",
    "electron-builder": "^26.8.1",
    "electron-vite": "^5.0.0",
    "eslint": "^10.3.0",
    "postcss": "^8.5.3",
    "tailwindcss": "^3.4.17",
    "tailwindcss-animate": "^1.0.7",
    "typescript": "^5.7.3",
    "vite": "^5.4.11"
  }
}
